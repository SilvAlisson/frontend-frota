# Variáveis de Ambiente — Frota KLIN Frontend
# Copie este arquivo como `.env` e preencha os valores reais.
# NUNCA commite o arquivo .env no git!

# URL base da API backend
VITE_API_URL=https://api.seudominio.com.br/api

# DSN do Sentry para monitoramento de erros em produção
# Gere um novo em: https://sentry.io/settings/[org]/projects/[project]/keys/
VITE_SENTRY_DSN=

# ID do Hotjar para análise de comportamento (opcional)
VITE_HOTJAR_ID=

# URL da aplicação (usada para gerar QR codes de login)
VITE_APP_URL=https://klinfrota.vercel.app
